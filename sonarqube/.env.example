# ── SonarQube Ports ───────────────────────────────────────────────────────
SONARQUBE_PORT=9000

# ── Database Password (REQUIRED) ──────────────────────────────────────────
# This password is used by both the sonarqube service (SONAR_JDBC_PASSWORD)
# and the postgres service (POSTGRES_PASSWORD). Both must match.
# Set a strong, unique password before starting for the first time.
# WARNING: Changing this after first start requires reinitialising the database.
SONAR_DB_PASSWORD=
