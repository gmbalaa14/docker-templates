# ── Kafka UI Port ─────────────────────────────────────────────────────────
# NOTE: Default port 8080 conflicts with Jenkins. Change one if running both.
KAFKA_UI_PORT=8080

# Clusters are configured through the Kafka UI web interface (no env vars needed).
# DYNAMIC_CONFIG_ENABLED=true is set in the compose file — open the UI and go to
# Settings > Configure new cluster to add clusters with full auth support.
