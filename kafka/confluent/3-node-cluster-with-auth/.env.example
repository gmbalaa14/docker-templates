# ── Host IP (REQUIRED) ────────────────────────────────────────────────────
# The IP address of your Docker host, used in KAFKA_ADVERTISED_LISTENERS so
# external clients can reach the brokers. Must be set before first start.
# Linux:  ip route get 1 | awk '{print $7; exit}'
# macOS:  ipconfig getifaddr en0
# Docker Desktop (Mac):    host.docker.internal
# Docker Desktop (Windows): use the host machine's LAN IP
KAFKA_HOST_IP=

# ── Cluster ID (REQUIRED) ─────────────────────────────────────────────────
# A unique base64-encoded UUID for this KRaft cluster.
# Generate with:
#   docker run --rm confluentinc/cp-kafka:7.8.0 kafka-storage random-uuid
# WARNING: Never share the same Cluster ID between two different clusters.
KAFKA_CLUSTER_ID=

# ── SASL Credentials (REQUIRED) ───────────────────────────────────────────
# Change these before connecting the cluster to any network.
KAFKA_ADMIN_PASSWORD=
KAFKA_TEST_PASSWORD=

# ── Broker Ports ──────────────────────────────────────────────────────────
KAFKA1_EXTERNAL_PORT=9092
KAFKA1_CONTROLLER_PORT=9093
KAFKA1_INTERNAL_PORT=29092

KAFKA2_EXTERNAL_PORT=9094
KAFKA2_CONTROLLER_PORT=9095
KAFKA2_INTERNAL_PORT=29093

KAFKA3_EXTERNAL_PORT=9096
KAFKA3_CONTROLLER_PORT=9097
KAFKA3_INTERNAL_PORT=29094
