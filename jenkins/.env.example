# ── Jenkins Ports ─────────────────────────────────────────────────────────
# NOTE: Default port 8080 conflicts with Kafka UI. Change one if running both.
JENKINS_PORT=8080
JENKINS_AGENT_PORT=50000

# ── Docker CLI Path ───────────────────────────────────────────────────────
# Path to the Docker CLI binary on your host.
# Find yours with: which docker
DOCKER_BIN=/usr/local/bin/docker
