# ── Headroom Proxy ────────────────────────────────────────────────────────
HEADROOM_PORT=8787

# ── Bind Host ─────────────────────────────────────────────────────────────
# 127.0.0.1  → localhost only (default, most secure — same machine only)
# 0.0.0.0    → all interfaces (allows other machines on the same network to connect)
#
# WARNING: Setting this to 0.0.0.0 exposes the proxy to your entire network.
# Ensure your firewall restricts access to trusted hosts only.
HEADROOM_BIND_HOST=127.0.0.1

# ── Timezone ──────────────────────────────────────────────────────────────
# Used by the container clock. Set to your local timezone.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Asia/Kolkata

# ── Features ──────────────────────────────────────────────────────────────
# Set to 1 to enable code-aware token optimization, 0 to disable.
HEADROOM_CODE_AWARE_ENABLED=1
