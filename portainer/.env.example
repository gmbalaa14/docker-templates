# ── Portainer Ports ───────────────────────────────────────────────────────
PORTAINER_HTTPS_PORT=9443
PORTAINER_TUNNEL_PORT=8000

# ── Authentication ────────────────────────────────────────────────────────
# Bcrypt hash of the Portainer admin password.
# Generate with:
#   docker run --rm httpd:2.4-alpine htpasswd -nbB admin 'your-password' | cut -d ':' -f 2
# The hash must be enclosed in single quotes in the compose file (already done).
PORTAINER_ADMIN_PASSWORD_HASH=
