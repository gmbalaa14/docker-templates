# ── Seq Ports ────────────────────────────────────────────────────────────
SEQ_INGEST_PORT=5341
SEQ_UI_PORT=8090

# ── Authentication ────────────────────────────────────────────────────────
# Bcrypt hash of the initial admin password set on first run.
# Generate with:
#   echo 'your-password' | docker run --rm -i datalust/seq config hash
# Leave blank to set the password interactively on first launch via the UI.
SEQ_ADMIN_PASSWORD_HASH=
